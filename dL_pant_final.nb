      "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Puntos dentro de 1\[Sigma]: \>\"", ",", 
     RowBox[{"Length", "[", "sigma1", "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Puntos dentro de 2\[Sigma]: \>\"", ",", 
     RowBox[{"Length", "[", "sigma2", "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Puntos dentro de 3\[Sigma]: \>\"", ",", 
     RowBox[{"Length", "[", "sigma3", "]"}]}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"BLOQUE", " ", "7"}], ":", 
     RowBox[{"PLOT", " ", "3", "D"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"puntos3D", "=", 
     RowBox[{"chiFlat", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{"2", ",", "4", ",", "1"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
   "Print", "[", "\"\<Figura 7: Plot 3D Chi2 vs OmegaM vs w\>\"", "]"}], "\n", 
   RowBox[{"ListPointPlot3D", "[", 
    RowBox[{"puntos3D", ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\[CapitalOmega]M\>\"", ",", "\"\<\[Chi]^2\>\"", ",", 
        "\"\<w\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", "\[Rule]", "\"\<\[Chi]^2 vs \[CapitalOmega]M vs w\>\""}], 
     ",", 
     RowBox[{"ColorFunction", "\[Rule]", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
        RowBox[{
         RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", "z", 
         "]"}]}], "]"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"PointSize", "[", "0.02", "]"}]}], ",", 
     RowBox[{"BoxRatios", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ",", 
     RowBox[{"ViewPoint", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"1.5", ",", 
        RowBox[{"-", "2.5"}], ",", "1.5"}], "}"}]}], ",", 
     RowBox[{"ViewVertical", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"BLOQUE", " ", "8"}], ":", 
     RowBox[{"BUCLE", " ", "FINO", " ", "Y", " ", "CONTOUR", " ", "PLOT"}]}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"listaFiltrada2", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"lista", ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "\[GreaterEqual]", "0.1"}], "&&", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "\[LessEqual]", "2.5"}]}], "&"}]}],
       "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"zObs3", "=", 
     RowBox[{"listaFiltrada2", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"muObs3", "=", 
     RowBox[{"listaFiltrada2", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sigmaObs3", "=", 
     RowBox[{"listaFiltrada2", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chiContour", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"om", "=", "omVal"}], ",", 
           RowBox[{"ode", "=", 
            RowBox[{"1", "-", "omVal"}]}]}], "}"}], ",", 
         RowBox[{
          RowBox[{"chi2", "=", 
           RowBox[{"Total", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Module", "[", 
               RowBox[{
                RowBox[{"{", "muTeo", "}"}], ",", 
                RowBox[{
                 RowBox[{"muTeo", "=", 
                  RowBox[{
                   RowBox[{"5", "*", 
                    RowBox[{"Log10", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    RowBox[{"zObs3", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"c", "/", "H0"}], ")"}], "*", 
                    RowBox[{"NIntegrate", "[", 
                    RowBox[{
                    RowBox[{"1", "/", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"om", "*", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"1", "+", "zp"}], ")"}], "^", "3"}]}], "+", 
                    RowBox[{"ode", "*", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"1", "+", "zp"}], ")"}], "^", 
                    RowBox[{"(", 
                    RowBox[{"3", "*", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", "wVal"}], ")"}]}], ")"}]}]}]}], "]"}]}],
                     ",", 
                    RowBox[{"{", 
                    RowBox[{"zp", ",", "0", ",", 
                    RowBox[{"zObs3", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
                    RowBox[{"AccuracyGoal", "\[Rule]", "4"}], ",", 
                    RowBox[{"PrecisionGoal", "\[Rule]", "4"}]}], "]"}]}], 
                    "]"}]}], "+", "25"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"muTeo", "-", 
                    RowBox[{"muObs3", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ")"}], "^", "2"}], "/", 
                  RowBox[{
                   RowBox[{"sigmaObs3", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}]}]}], "]"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", 
                RowBox[{"Length", "[", "zObs3", "]"}]}], "}"}]}], "]"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"omVal", ",", "wVal", ",", "chi2"}], "}"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"omVal", ",", "0.2", ",", "0.5", ",", "0.006"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"wVal", ",", 
         RowBox[{"-", "1.3"}], ",", 
         RowBox[{"-", "0.7"}], ",", "0.012"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chiContourFlat", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"chiContour", ",", "1"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chiMinContour", "=", 
     RowBox[{"Min", "[", 
      RowBox[{"chiContourFlat", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"minPosContour", "=", 
     RowBox[{
      RowBox[{"MinimalBy", "[", 
       RowBox[{"chiContourFlat", ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{
    "\"\<Minimo contour: \[Chi]^2 = \>\"", ",", "chiMinContour", ",", 
     "\"\< en OmegaM = \>\"", ",", 
     RowBox[{"minPosContour", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<, w = \>\"", ",", 
     RowBox[{"minPosContour", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chiDeltaContour", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "3", "]"}], "]"}], "-", "chiMinContour"}]}], "}"}], 
       "&"}], "/@", "chiContourFlat"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
   "Print", "[", "\"\<Figura 8: Contour plot niveles de confianza\>\"", "]"}],
    "\n", 
   RowBox[{"ListContourPlot", "[", 
    RowBox[{"chiDeltaContour", ",", 
     RowBox[{"Contours", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"2.30", ",", "6.17", ",", "11.83"}], "}"}]}], ",", 
     RowBox[{"ContourStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Blue", ",", "Thick"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Green", ",", "Thick"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Red", ",", "Thick"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<w\>\"", ",", "None"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\"\<\[CapitalOmega]M\>\"", ",", "None"}], "}"}]}], "}"}]}], 
     ",", 
     RowBox[{
     "PlotLabel", "\[Rule]", 
      "\"\<\[CapitalDelta]\[Chi]^2 - Niveles de confianza (Pantheon+)\>\""}], 
     ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"LineLegend", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Blue", ",", "Green", ",", "Red"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
           "\"\<1\[Sigma] (\[CapitalDelta]\[Chi]^2 = 2.30)\>\"", ",", 
            "\"\<2\[Sigma] (\[CapitalDelta]\[Chi]^2 = 6.17)\>\"", ",", 
            "\"\<3\[Sigma] (\[CapitalDelta]\[Chi]^2 = 11.83)\>\""}], "}"}]}], 
         "]"}], ",", "Right"}], "]"}]}], ",", 
     RowBox[{"Epilog", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Black", ",", 
        RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
        RowBox[{"Point", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"minPosContour", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"minPosContour", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0.30", ",", "0.50"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1.00"}], ",", 
          RowBox[{"-", "0.70"}]}], "}"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Frame", "\[Rule]", "True"}], ",", 
     RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]}]}]], "Input",
