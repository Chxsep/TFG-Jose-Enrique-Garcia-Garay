      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", "z"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"c", "/", "H0"}], ")"}], "*", 
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"om", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "+", "zp"}], ")"}], "^", "3"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "om"}], ")"}], "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "+", "zp"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"3", "*", 
                RowBox[{"(", 
                 RowBox[{"1", "+", "wVal"}], ")"}]}], ")"}]}]}]}], "]"}]}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"zp", ",", "0", ",", "z"}], "}"}], ",", 
         RowBox[{"AccuracyGoal", "\[Rule]", "4"}], ",", 
         RowBox[{"PrecisionGoal", "\[Rule]", "4"}]}], "]"}]}], "]"}]}], "+", 
    "25"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
