Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"muTeo", ",", "chi2Cov"}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"H0", "=", "70.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"c", "=", "299792.458"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Leer", " ", "datos", " ", "Pantheon"}], "+"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Import", "[", 
     RowBox[{
     "\"\<C:\\\\Users\\\\joses\\\\OneDrive\\\\Documents\\\\Mathematica\\\\\
Pantheon+SH0ES.dat\>\"", ",", "\"\<Table\>\"", ",", 
      RowBox[{"\"\<HeaderLines\>\"", "\[Rule]", "1"}]}], "]"}]}], ";"}], "\n",
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Guardar", " ", "indices", " ", "originales", " ", "antes", " ", "de", " ",
     "filtrar", " ", "para", " ", "usarlos", " ", "en", " ", "la", " ", 
    "covmat"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"todosNumericos", "=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"Range", "[", 
       RowBox[{"Length", "[", "data", "]"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"AllTrue", "[", 
         RowBox[{
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{"#", ",", 
             RowBox[{"{", 
              RowBox[{"3", ",", "11", ",", "12"}], "}"}]}], "]"}], "]"}], ",",
           "NumericQ"}], "]"}], "&&", 
        RowBox[{
         RowBox[{"data", "[", 
          RowBox[{"[", 
           RowBox[{"#", ",", "11"}], "]"}], "]"}], "\[NotEqual]", 
         RowBox[{"-", "9"}]}]}], "&"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lista", "=", 
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"todosNumericos", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "11", ",", "12"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"zObs", "=", 
   RowBox[{"lista", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"muObs", "=", 
   RowBox[{"lista", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"n", "=", 
   RowBox[{"Length", "[", "zObs", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Numero de supernovas filtradas: \>\"", ",", "n"}], "]"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Leer", " ", "matriz", " ", "de", " ", "covarianza"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Primera", " ", "linea"}], "=", 
     RowBox[{"dimension", " ", 
      RowBox[{"(", "1701", ")"}]}]}], ",", 
    RowBox[{"luego", " ", "valores", " ", "uno", " ", "por", " ", "linea"}]}],
    "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"covRaw", "=", 
   RowBox[{"Import", "[", 
    RowBox[{
    "\"\<C:\\\\Users\\\\joses\\\\OneDrive\\\\Documents\\\\Mathematica\\\\\
Pantheon+SH0ES_STAT+SYS.cov\>\"", ",", "\"\<Table\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"nCov", "=", 
   RowBox[{"covRaw", "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Dimension matriz covarianza: \>\"", ",", "nCov"}], "]"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"covVals", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"covRaw", "[", 
     RowBox[{"[", 
      RowBox[{"2", ";;"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"CovMat", "=", 
   RowBox[{"N", "[", 
    RowBox[{"Partition", "[", 
     RowBox[{"covVals", ",", "nCov"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Dimensiones CovMat: \>\"", ",", 
    RowBox[{"Dimensions", "[", "CovMat", "]"}]}], "]"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Recortar", " ", "con", " ", "los", " ", "indices", " ", "correctos"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CovMatN", "=", 
   RowBox[{"CovMat", "[", 
    RowBox[{"[", 
     RowBox[{"todosNumericos", ",", "todosNumericos"}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"CovInv", "=", 
   RowBox[{"Inverse", "[", "CovMatN", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Matriz invertida correctamente, dimension: \>\"", ",", 
    RowBox[{"Dimensions", "[", "CovInv", "]"}]}], "]"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Modulo", " ", "de", " ", "distancia", " ", "teorico"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"muTeo", "[", 
    RowBox[{"z_", ",", "om_", ",", "wVal_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"5", "*", 
     RowBox[{"Log10", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", "z"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"c", "/", "H0"}], ")"}], "*", 
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"om", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "+", "zp"}], ")"}], "^", "3"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "om"}], ")"}], "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "+", "zp"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"3", "*", 
                RowBox[{"(", 
                 RowBox[{"1", "+", "wVal"}], ")"}]}], ")"}]}]}]}], "]"}]}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"zp", ",", "0", ",", "z"}], "}"}], ",", 
         RowBox[{"AccuracyGoal", "\[Rule]", "4"}], ",", 
         RowBox[{"PrecisionGoal", "\[Rule]", "4"}]}], "]"}]}], "]"}]}], "+", 
    "25"}]}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Chi", " ", "cuadrado", " ", "con", " ", "matriz", " ", "de", " ", 
    "covarianza"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"chi2Cov", "[", 
    RowBox[{"om_", ",", "wVal_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "delta", "}"}], ",", 
     RowBox[{
      RowBox[{"delta", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"muTeo", "[", 
           RowBox[{
            RowBox[{"zObs", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", "om", ",", "wVal"}], "]"}], 
          "-", 
          RowBox[{"muObs", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"delta", ".", "CovInv", ".", "delta"}]}]}], "]"}]}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Bucle", " ", "2", 
     RowBox[{"D", ":", 
      RowBox[{"OmegaM", " ", "de", " ", "0.2", " ", "a", " ", "0.5", " ", 
       RowBox[{"(", 
        RowBox[{"paso", " ", "0.006"}], ")"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"w", " ", "de"}], "-", 
     RowBox[{"1.3", " ", "a"}], "-", 
     RowBox[{"0.7", " ", 
      RowBox[{"(", 
       RowBox[{"paso", " ", "0.012"}], ")"}]}]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  "\"\<Calculando chi cuadrado con matriz de covarianza...\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"chiContour", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"omVal", ",", "wVal", ",", 
        RowBox[{"chi2Cov", "[", 
         RowBox[{"omVal", ",", "wVal"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"omVal", ",", "0.2", ",", "0.5", ",", "0.006"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"wVal", ",", 
        RowBox[{"-", "1.3"}], ",", 
        RowBox[{"-", "0.7"}], ",", "0.012"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"chiContourFlat", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{"chiContour", ",", "1"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Minimo", " ", "y", " ", "delta", " ", "chi", " ", "cuadrado"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chiMinContour", "=", 
   RowBox[{"Min", "[", 
    RowBox[{"chiContourFlat", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"minPos", "=", 
   RowBox[{
    RowBox[{"MinimalBy", "[", 
     RowBox[{"chiContourFlat", ",", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "3", "]"}], "]"}], "&"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{
   "\"\<Minimo global: \[Chi]^2 = \>\"", ",", "chiMinContour", ",", 
    "\"\< en OmegaM = \>\"", ",", 
    RowBox[{"minPos", "[", 
     RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<, w = \>\"", ",", 
    RowBox[{"minPos", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"chiDeltaContour", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "-", "chiMinContour"}]}], "}"}], 
      "&"}], "/@", "chiContourFlat"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Niveles", " ", "de", " ", "confianza"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sigma1", "=", 
