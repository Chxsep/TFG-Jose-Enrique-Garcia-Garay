         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
        RowBox[{"datosP", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "3"}], "]"}], "]"}]}], "}"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Contour", " ", "SCP", " ", "Union2", ".1"}], "-", 
     RowBox[{"tonos", " ", "azules"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"contU", "=", 
     RowBox[{"ListContourPlot", "[", 
      RowBox[{"puntosU", ",", 
       RowBox[{"Contours", "\[Rule]", 
